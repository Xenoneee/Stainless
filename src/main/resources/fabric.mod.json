{
  "schemaVersion": 1,
  "id": "stainless",
  "version": "${version}",
  "name": "Stainless",
  "description": "1.21.5 Meteor Client addon for cpvp/utilities..",
  "authors": [
    "Xenon_ne"
  ],
  "contact": {
    "sources": "https://github.com/Xenoneee/Stainless",
    "issues": "https://github.com/Xenoneee/Stainless/issues"
  },
